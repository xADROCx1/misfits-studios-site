# Copy this file to `.env` and fill in real values.
# The `.env` file is git-ignored (see .gitignore) — never commit it.

# REQUIRED — create at https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_api_key_here

# OPTIONAL — if you have multiple LS stores, set this to scope the sync to one.
# Find it in the LS dashboard URL or via GET /v1/stores.
LEMONSQUEEZY_STORE_ID=
