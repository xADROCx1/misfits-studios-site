# Copy this file to `.env` and fill in real values.
# The `.env` file is git-ignored (see .gitignore) — never commit it.

# =============================================================
# LEMON SQUEEZY — used by sync-from-lemonsqueezy.js
# =============================================================
# Create at https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
# Optional: scope sync to one store (find in dashboard URL or GET /v1/stores)
LEMONSQUEEZY_STORE_ID=

# =============================================================
# PADDLE — used by sync-from-paddle.js + bulk-create-paddle-products.js
# =============================================================
# Create at https://vendors.paddle.com/ → Developer tools → Authentication
# LIVE keys start with pdl_live_apikey_... · SANDBOX with pdl_sdbx_apikey_...
PADDLE_API_KEY=
PADDLE_SANDBOX_API_KEY=

# Client-side token for Paddle.js overlay checkout.
# Public / safe to embed in HTML — different from the API key above.
# Create in the same Authentication panel as the API key.
# scripts/inject-paddle-token.js reads this and stamps it into every
# HTML <head> so Paddle.Initialize({ token }) works on the client.
PADDLE_CLIENT_TOKEN=
